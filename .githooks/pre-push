#!/usr/bin/env sh
# =============================================================================
# pre-push — TypeScript + Build checks
# =============================================================================
# Runs on every `git push`. Slower checks that catch real errors before they
# land in the remote.
#
#   1. tsc --noEmit               → TS type errors in the docs app
#   2. tsc --noEmit (design sys)  → TS type errors in @work-rjkashyap/unified-ui
#   3. tsup (dry-run build)       → design system build errors
#
# To skip in an emergency:  git push --no-verify
# =============================================================================

set -e

BOLD="\033[1m"
RED="\033[31m"
GREEN="\033[32m"
YELLOW="\033[33m"
CYAN="\033[36m"
RESET="\033[0m"

echo ""
echo "${BOLD}${CYAN}▶ pre-push${RESET}"
echo ""

# ---------------------------------------------------------------------------
# 1. TypeScript — docs app (root tsconfig)
# ---------------------------------------------------------------------------
echo "  ${YELLOW}[1/3]${RESET} TypeScript check — docs app..."

if ! npx tsc --noEmit 2>&1; then
  echo ""
  echo "  ${RED}✘ TypeScript errors in docs app.${RESET} Fix them before pushing."
  echo ""
  exit 1
fi

echo "  ${GREEN}✔${RESET} Docs app types OK"

# ---------------------------------------------------------------------------
# 2. TypeScript — design system package
# ---------------------------------------------------------------------------
echo "  ${YELLOW}[2/3]${RESET} TypeScript check — design system package..."

if ! npm run typecheck --workspace=@work-rjkashyap/unified-ui 2>&1; then
  echo ""
  echo "  ${RED}✘ TypeScript errors in @work-rjkashyap/unified-ui.${RESET} Fix them before pushing."
  echo ""
  exit 1
fi

echo "  ${GREEN}✔${RESET} Design system types OK"

# ---------------------------------------------------------------------------
# 3. Build — design system (tsup)
# ---------------------------------------------------------------------------
echo "  ${YELLOW}[3/3]${RESET} Build check — design system (tsup)..."

if ! npm run build:ds 2>&1; then
  echo ""
  echo "  ${RED}✘ Design system build failed.${RESET} Fix the errors above before pushing."
  echo ""
  exit 1
fi

echo "  ${GREEN}✔${RESET} Design system build OK"
echo ""
echo "${GREEN}${BOLD}✔ pre-push passed${RESET} — pushing to remote."
echo ""
