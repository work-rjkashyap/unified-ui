{
  "name": "@work-rjkashyap/unified-ui",
  "version": "0.1.0",
  "description": "A scalable, token-driven React design system built with Tailwind CSS v4 and Framer Motion.",
  "author": "Rajeshwar Kashyap",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/work-rjkashyap/unified-ui",
    "directory": "packages/unified-ui"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "./styles.css",
    "./dist/**/*.css"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./tokens": {
      "import": {
        "types": "./dist/tokens.d.ts",
        "default": "./dist/tokens.mjs"
      },
      "require": {
        "types": "./dist/tokens.d.cts",
        "default": "./dist/tokens.cjs"
      }
    },
    "./theme": {
      "import": {
        "types": "./dist/theme.d.ts",
        "default": "./dist/theme.mjs"
      },
      "require": {
        "types": "./dist/theme.d.cts",
        "default": "./dist/theme.cjs"
      }
    },
    "./primitives": {
      "import": {
        "types": "./dist/primitives.d.ts",
        "default": "./dist/primitives.mjs"
      },
      "require": {
        "types": "./dist/primitives.d.cts",
        "default": "./dist/primitives.cjs"
      }
    },
    "./components": {
      "import": {
        "types": "./dist/components.d.ts",
        "default": "./dist/components.mjs"
      },
      "require": {
        "types": "./dist/components.d.cts",
        "default": "./dist/components.cjs"
      }
    },
    "./motion": {
      "import": {
        "types": "./dist/motion.d.ts",
        "default": "./dist/motion.mjs"
      },
      "require": {
        "types": "./dist/motion.d.cts",
        "default": "./dist/motion.cjs"
      }
    },
    "./utils": {
      "import": {
        "types": "./dist/utils.d.ts",
        "default": "./dist/utils.mjs"
      },
      "require": {
        "types": "./dist/utils.d.cts",
        "default": "./dist/utils.cjs"
      }
    },
    "./styles.css": "./styles.css"
  },
  "typesVersions": {
    "*": {
      "tokens": [
        "./dist/tokens.d.ts"
      ],
      "theme": [
        "./dist/theme.d.ts"
      ],
      "primitives": [
        "./dist/primitives.d.ts"
      ],
      "components": [
        "./dist/components.d.ts"
      ],
      "motion": [
        "./dist/motion.d.ts"
      ],
      "utils": [
        "./dist/utils.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "styles.css",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "react",
    "design-system",
    "tailwindcss",
    "tailwind",
    "components",
    "ui",
    "unified-ui",
    "tokens",
    "framer-motion",
    "accessibility",
    "radix-ui"
  ],
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0",
    "tailwindcss": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": true
    }
  },
  "dependencies": {
    "@work-rjkashyap/unified-ui": "^0.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.4.0"
  },
  "optionalDependencies": {
    "@radix-ui/react-accordion": ">=1.2.0",
    "@radix-ui/react-checkbox": ">=1.3.0",
    "@radix-ui/react-dialog": ">=1.1.0",
    "@radix-ui/react-dropdown-menu": ">=2.1.0",
    "@radix-ui/react-popover": ">=1.1.0",
    "@radix-ui/react-radio-group": ">=1.3.0",
    "@radix-ui/react-select": ">=2.2.0",
    "@radix-ui/react-switch": ">=1.2.0",
    "@radix-ui/react-tabs": ">=1.1.0",
    "@radix-ui/react-tooltip": ">=1.2.0",
    "framer-motion": ">=12.0.0"
  },
  "devDependencies": {
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "framer-motion": "^12.34.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
