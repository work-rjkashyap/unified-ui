{
  "$schema": "https://biomejs.dev/schemas/2.4.4/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!node_modules",
      "!.next",
      "!dist",
      "!build",
      "!.source",
      "!packages/*/dist"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double"
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    },
    "domains": {
      "next": "recommended",
      "react": "recommended"
    }
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "overrides": [
    {
      "includes": ["packages/unified-ui/**"],
      "linter": {
        "rules": {
          "performance": {
            "noImgElement": "off"
          },
          "a11y": {
            "useSemanticElements": "off",
            "useFocusableInteractive": "off",
            "noStaticElementInteractions": "off",
            "useAriaPropsSupportedByRole": "off",
            "noSvgWithoutTitle": "off"
          },
          "suspicious": {
            "noArrayIndexKey": "off",
            "noExplicitAny": "off",
            "noDocumentCookie": "off"
          },
          "correctness": {
            "useHookAtTopLevel": "off"
          },
          "style": {
            "noNonNullAssertion": "off"
          },
          "security": {
            "noDangerouslySetInnerHtml": "off"
          }
        }
      }
    },
    {
      "includes": [
        "src/components/layout/**",
        "src/components/home/**",
        "src/components/toc/**",
        "src/components/ai/**"
      ],
      "linter": {
        "rules": {
          "suspicious": {
            "noArrayIndexKey": "off",
            "noExplicitAny": "off",
            "useIterableCallbackReturn": "off"
          },
          "correctness": {
            "useHookAtTopLevel": "off"
          },
          "style": {
            "noNonNullAssertion": "off"
          },
          "a11y": {
            "useButtonType": "off",
            "useKeyWithClickEvents": "off",
            "noStaticElementInteractions": "off"
          }
        }
      }
    },
    {
      "includes": ["scripts/**"],
      "linter": {
        "rules": {
          "suspicious": {
            "noAssignInExpressions": "off"
          }
        }
      }
    },
    {
      "includes": ["starters/**", "template/**"],
      "linter": {
        "rules": {
          "performance": {
            "noImgElement": "off"
          },
          "a11y": {
            "useSemanticElements": "off",
            "useFocusableInteractive": "off",
            "noStaticElementInteractions": "off",
            "useAriaPropsSupportedByRole": "off",
            "noSvgWithoutTitle": "off"
          },
          "suspicious": {
            "noArrayIndexKey": "off",
            "noExplicitAny": "off",
            "noDocumentCookie": "off"
          },
          "correctness": {
            "useHookAtTopLevel": "off"
          },
          "style": {
            "noNonNullAssertion": "off"
          },
          "security": {
            "noDangerouslySetInnerHtml": "off"
          }
        }
      }
    },
    {
      "includes": ["src/app/**"],
      "linter": {
        "rules": {
          "suspicious": {
            "noArrayIndexKey": "off"
          },
          "a11y": {
            "noSvgWithoutTitle": "off",
            "noLabelWithoutControl": "off"
          }
        }
      }
    },
    {
      "includes": ["src/components/**"],
      "linter": {
        "rules": {
          "suspicious": {
            "noArrayIndexKey": "off",
            "noMisleadingCharacterClass": "off"
          }
        }
      }
    }
  ]
}
